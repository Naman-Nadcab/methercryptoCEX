{
  "name": "@exchange/backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Crypto Exchange Backend API",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "dev:node-match": "USE_RUST_MATCHING_ENGINE=false tsx watch src/server.ts",
    "dev:express": "echo 'DEPRECATED: Use dev (Fastify). Express path is legacy.' && tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "start:api": "RUN_MODE=api node dist/server.js",
    "start:workers": "RUN_MODE=workers node dist/server.js",
    "lint": "eslint src --ext .ts",
    "migrate": "tsx src/database/migrate.ts",
    "migrate:down": "tsx src/database/migrate.ts down",
    "fix:wallets-chain-id": "tsx fix-wallets-chain-id.ts",
    "ensure:wallets": "tsx ensure-wallets-relation.ts",
    "clean": "rm -rf dist",
    "test:balance": "tsx src/services/balance/balance-read.integration.test.ts",
    "test:p2p-orders": "tsx src/routes/p2p-orders.integration.test.ts",
    "test:admin-rbac": "tsx src/lib/admin-rbac-routes.test.ts",
    "test:admin-ops": "tsx src/routes/admin-operations.integration.test.ts",
    "test:tier1-alerts": "tsx scripts/tier1-alert-verify.ts",
    "load-historical-candles": "tsx scripts/load-historical-candles.ts",
    "backfill:opening-ledger": "tsx scripts/backfill-opening-balance-ledger.ts",
    "settlement:reset": "tsx scripts/reset-failed-settlement-events.ts",
    "prelaunch:db": "tsx scripts/prelaunch-db-check.ts",
    "tier1:phase1-verify": "tsx scripts/tier1-phase1-verify.ts",
    "tier1:phase2-verify": "tsx scripts/tier1-phase2-verify.ts",
    "tier1:phase3-verify": "tsx scripts/tier1-phase3-verify.ts",
    "tier1:phase4-verify": "tsx scripts/tier1-phase4-verify.ts",
    "tier1:fiu-readiness": "tsx scripts/tier1-fiu-readiness-verify.ts",
    "tier1:drain-settlement": "tsx scripts/tier1-drain-settlement.ts",
    "tier1:release-check:db": "npm run tier1:phase1-verify && npm run tier1:fiu-readiness",
    "tier1:release-check:full": "npm run tier1:release-check:db && npm run tier1:phase2-verify && npm run tier1:phase3-verify",
    "tier1:release-check:strict": "TIER1_REQUIRE_ZERO_PENDING_SETTLEMENT=true npm run tier1:phase1-verify && TIER1_REQUIRE_ZERO_PENDING_SETTLEMENT=true npm run tier1:fiu-readiness && TIER1_REQUIRE_ZERO_PENDING_SETTLEMENT=true npm run tier1:phase2-verify && TIER1_REQUIRE_ZERO_PENDING_SETTLEMENT=true npm run tier1:phase3-verify",
    "test:phase0-security": "tsx scripts/phase0-security-verify.ts",
    "test:phase1-final-security": "tsx scripts/phase1-final-security-verify.ts",
    "test:phase1-chaos-redis": "PHASE1_VERIFY_REDIS_MODE=degraded tsx scripts/phase1-chaos-redis-subprocess.ts && PHASE1_VERIFY_REDIS_MODE=strict tsx scripts/phase1-chaos-redis-subprocess.ts",
    "test:phase2-treasury": "tsx scripts/phase2-treasury-verify.ts",
    "test:phase3-hardening": "tsx scripts/phase3-ultra-hardening-verify.ts",
    "test:launch-validation": "tsx scripts/launch-security-validation.ts",
    "admin:reset-dev-login": "tsx scripts/reset-admin-dev-login.ts",
    "qa:database-target": "tsx scripts/print-database-target.ts",
    "verify:admin-hybrid": "tsx scripts/verify-admin-hybrid.ts",
    "start:signing-service": "node dist/signing/signing-http-main.js"
  },
  "dependencies": {
    "@aws-sdk/client-kms": "^3.989.0",
    "@fastify/compress": "^8.3.1",
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.2.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/jwt": "^10.0.0",
    "@fastify/multipart": "^9.4.0",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/static": "^9.0.0",
    "@fastify/swagger": "^9.6.1",
    "@fastify/swagger-ui": "^5.2.5",
    "@fastify/websocket": "^11.2.0",
    "@polkadot/keyring": "^14.0.1",
    "@polkadot/util": "^14.0.1",
    "@sentry/node": "^10.42.0",
    "@simplewebauthn/server": "^13.2.2",
    "@solana/web3.js": "^1.98.4",
    "@types/nodemailer": "^7.0.9",
    "@types/web-push": "^3.6.4",
    "amqplib": "^0.10.3",
    "bcryptjs": "^2.4.3",
    "bip32": "^5.0.0",
    "bitcoinjs-lib": "^7.0.1",
    "compression": "^1.7.4",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "decimal.js": "^10.4.3",
    "dotenv": "^16.3.1",
    "ethers": "^6.9.0",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "express-validator": "^7.0.1",
    "fastify": "^5.7.2",
    "helmet": "^7.1.0",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "nats": "^2.29.3",
    "nodemailer": "^6.10.1",
    "otpauth": "^9.4.1",
    "pg": "^8.11.3",
    "pino-pretty": "^13.1.3",
    "prom-client": "^15.1.3",
    "qrcode": "^1.5.4",
    "tiny-secp256k1": "^2.2.4",
    "tronweb": "^6.1.1",
    "uuid": "^9.0.1",
    "web-push": "^3.6.7",
    "winston": "^3.11.0",
    "ws": "^8.14.2",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/amqplib": "^0.10.4",
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.7.5",
    "@types/cookie-parser": "^1.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/morgan": "^1.9.9",
    "@types/node": "^20.10.4",
    "@types/pg": "^8.10.9",
    "@types/uuid": "^9.0.7",
    "@types/ws": "^8.5.10",
    "tsx": "^4.6.2",
    "typescript": "^5.3.3"
  }
}
