# ===========================================
# CRYPTO EXCHANGE - ENVIRONMENT CONFIGURATION
# ===========================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# ===========================================
# DATABASE
# ===========================================
DATABASE_URL=postgresql://user:password@host:port/database?sslmode=require
DATABASE_POOL_MIN=5
DATABASE_POOL_MAX=20

# ===========================================
# REDIS
# ===========================================
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=
REDIS_TLS_ENABLED=false

# ===========================================
# RABBITMQ
# ===========================================
RABBITMQ_URL=amqp://guest:guest@localhost:5672

# ===========================================
# JWT & AUTH
# ===========================================
JWT_SECRET=your-super-secret-jwt-key-min-32-chars
JWT_REFRESH_SECRET=your-refresh-token-secret-min-32-chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ===========================================
# ENCRYPTION (AES-256)
# ===========================================
ENCRYPTION_KEY=your-32-byte-encryption-key-here
ENCRYPTION_IV_LENGTH=16

# ===========================================
# HSM CONFIGURATION (Production)
# ===========================================
HSM_ENABLED=false
HSM_SLOT_ID=0
HSM_PIN=
HSM_LIBRARY_PATH=/usr/lib/softhsm/libsofthsm2.so

# ===========================================
# OAUTH PROVIDERS
# ===========================================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google/callback

APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=
APPLE_CALLBACK_URL=http://localhost:3000/api/auth/apple/callback

TELEGRAM_BOT_TOKEN=

# ===========================================
# EMAIL SERVICE
# ===========================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=noreply@exchange.com

# ===========================================
# SMS SERVICE (Abstract Provider)
# ===========================================
SMS_PROVIDER=twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ===========================================
# KYC PROVIDERS
# ===========================================
KYC_PROVIDER=hyperverge
HYPERVERGE_APP_ID=
HYPERVERGE_APP_KEY=
HYPERVERGE_BASE_URL=https://ind.idv.hyperverge.co/v1

# ===========================================
# BLOCKCHAIN RPC ENDPOINTS
# ===========================================
# EVM Chains
ETH_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/your-key
ETH_WS_URL=wss://eth-mainnet.g.alchemy.com/v2/your-key
BSC_RPC_URL=https://bsc-dataseed.binance.org
POLYGON_RPC_URL=https://polygon-rpc.com
ARBITRUM_RPC_URL=https://arb1.arbitrum.io/rpc
OPTIMISM_RPC_URL=https://mainnet.optimism.io
BASE_RPC_URL=https://mainnet.base.org

# Solana
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
SOLANA_WS_URL=wss://api.mainnet-beta.solana.com

# Tron
TRON_API_URL=https://api.trongrid.io
TRON_API_KEY=

# Bitcoin
BITCOIN_RPC_URL=http://localhost:8332
BITCOIN_RPC_USER=
BITCOIN_RPC_PASSWORD=
BITCOIN_NETWORK=mainnet

# ===========================================
# HOT WALLET (Master Seed - HIGHLY SENSITIVE)
# ===========================================
MASTER_SEED_ENCRYPTED=
MASTER_SEED_KEY_ID=

# ===========================================
# APPLICATION
# ===========================================
NODE_ENV=development
PORT=4000
FRONTEND_URL=http://localhost:3000
API_VERSION=v1

# ===========================================
# RATE LIMITING
# ===========================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_SKIP_SUCCESSFUL_REQUESTS=false

# ===========================================
# SECURITY
# ===========================================
CORS_ORIGINS=http://localhost:3000
TRUSTED_PROXIES=1
ADMIN_IP_WHITELIST=127.0.0.1,::1
SESSION_SECRET=your-session-secret-min-32-chars
CSRF_SECRET=your-csrf-secret-min-32-chars

# ===========================================
# MONITORING & LOGGING
# ===========================================
LOG_LEVEL=debug
SENTRY_DSN=
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090

# ===========================================
# FEATURE FLAGS
# ===========================================
FEATURE_P2P_ENABLED=true
FEATURE_SPOT_TRADING_ENABLED=true
FEATURE_MARGIN_TRADING_ENABLED=false
FEATURE_FUTURES_ENABLED=false
MAINTENANCE_MODE=false
