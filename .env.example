# ===========================================
# CRYPTO EXCHANGE - ENVIRONMENT CONFIGURATION
# ===========================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control

# ===========================================
# DATABASE
# ===========================================
DATABASE_URL=postgresql://user:password@host:port/database?sslmode=require
DATABASE_POOL_MIN=5
DATABASE_POOL_MAX=20
# SSL cert verification. Set false for dev/Supabase. Production: use true.
DATABASE_SSL_REJECT_UNAUTHORIZED=true
# Read replica for heavy SELECTs (optional)
# DATABASE_READ_REPLICA_URL=postgresql://readonly:pass@replica:5432/db

# ===========================================
# REDIS
# ===========================================
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=
REDIS_TLS_ENABLED=false
# Redis Sentinel (HA): REDIS_SENTINELS=host1:26379,host2:26379 REDIS_SENTINEL_MASTER=mymaster
# Enable Redis Pub/Sub for Spot WebSocket multi-instance scaling
REDIS_WS_PUBSUB_ENABLED=false
# persistent = reconnect forever with capped backoff (Tier-1 default). limited = stop after ~20 attempts.
REDIS_RETRY_MODE=persistent
# Bring up local deps: npm run infra:up   (redis, postgres, rabbitmq, nats)

# ===========================================
# STARTUP & /health (Tier-1)
# ===========================================
# Exit process if Redis cannot connect (also when TIER1_LAUNCH=true or NODE_ENV=production if unset).
# STRICT_DEPENDENCY_STARTUP=false
# TIER1_LAUNCH=false
# Production /health also checks NATS JetStream streams + Rust engine when those features are enabled.
# Override gates: HEALTH_REQUIRE_NATS=true|false|auto  HEALTH_REQUIRE_MATCHING_ENGINE=true|false|auto
# HEALTH_FAIL_ON_STALE_INDEXER=false
# HEALTH_INDEXER_MAX_LAG_SEC=300
#
# Deposit indexer (optional: docker compose service `indexer` on port 4001)
# INDEXER_API_URL=http://localhost:4001
#
# Tier 1 release gates (API + DB must be reachable):
# npm run tier1:phase1-verify   — DB: trading ledger vs balances + settlement hash chain
# npm run tier1:phase2-verify — above + GET /api/v1/p2p/ads
# npm run tier1:phase3-verify — above + GET /health + npm run test:security
# One-shot: npm run tier1:release-check:db (DB only) | tier1:release-check:full (needs API on E2E_BASE_URL)
# Cutover: npm run tier1:release-check:strict (pending settlement must be 0) + optional TIER1_FIU_STRICT=true
# Staging/prod cutover: require settlement worker drained (no pending settlement_events)
# TIER1_REQUIRE_ZERO_PENDING_SETTLEMENT=true
# Drain pending settlement_events (DB + Redis; API may be off): npm run tier1:drain-settlement
# TIER1_DRAIN_MAX_ITERATIONS=500
# E2E_BASE_URL=http://127.0.0.1:4000
# TIER1_PHASE3_SKIP_SECURITY=true   # CI without running API
# TIER1_ALLOW_HEALTH_NON_200=true   # allow /health HTTP != 200 (not recommended)
# TIER1_PHASE3_INCLUDE_E2E=true     # also run npm run test:e2e (needs JWT env; often flaky in CI)
#
# When Prometheus scrapes /metrics, evaluate Tier-1 rules locally and log ALERT_TRIGGERED if
# indexer lag or WS disconnect spike thresholds match (see apps/backend/prometheus/alerts/spot-tier1.rules.yml).
# TIER1_ALERT_EVAL_ON_METRICS=true
# /health warnings when disconnect rate between scrapes exceeds (approximate):
# HEALTH_WS_DISCONNECT_WARN_PER_SEC=5
# Slow or remote Postgres: raise DB ping timeout (default 8000 ms).
# HEALTH_DATABASE_PING_TIMEOUT_MS=15000
# Startup + /health: SELECT 1 attempts (1 = fastest; 3–5 for flaky networks). Default 4.
# HEALTH_DATABASE_PING_MAX_ATTEMPTS=4
# Exponential backoff base (ms) between failed attempts. Default 400.
# HEALTH_DATABASE_PING_RETRY_BASE_MS=400
#
# If GET /health returns 503, read JSON: `unhealthy_reasons`, `failed_services`, and `services`.
# Common fix: Postgres not running, or DATABASE_URL host wrong for your runtime (use localhost:5432 from host,
# postgres:5432 from inside Docker network).

# ===========================================
# POSTGRES (for docker-compose)
# ===========================================
POSTGRES_USER=exchange
POSTGRES_PASSWORD=exchange_secret
POSTGRES_DB=exchange

# ===========================================
# RABBITMQ
# ===========================================
RABBITMQ_URL=amqp://guest:guest@localhost:5672

# ===========================================
# JWT & AUTH
# ===========================================
JWT_SECRET=your-super-secret-jwt-key-min-32-chars
JWT_REFRESH_SECRET=your-refresh-token-secret-min-32-chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ===========================================
# ENCRYPTION (AES-256)
# ===========================================
ENCRYPTION_KEY=your-32-byte-encryption-key-here
ENCRYPTION_IV_LENGTH=16

# ===========================================
# HSM CONFIGURATION (Production)
# ===========================================
HSM_ENABLED=false
HSM_SLOT_ID=0
HSM_PIN=
HSM_LIBRARY_PATH=/usr/lib/softhsm/libsofthsm2.so

# ===========================================
# KMS / ENVELOPE ENCRYPTION (Hot wallet keys)
# ===========================================
# local = derive master from ENCRYPTION_KEY + key version (dev/single-node)
# aws  = use AWS KMS (set AWS_KMS_KEY_ID + AWS_REGION; requires @aws-sdk/client-kms)
KMS_TYPE=local
KMS_KEY_VERSION=1
# AWS_KMS_KEY_ID=
# AWS_REGION=us-east-1

# ===========================================
# OAUTH PROVIDERS
# ===========================================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google/callback

APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=
APPLE_CALLBACK_URL=http://localhost:3000/api/auth/apple/callback

TELEGRAM_BOT_TOKEN=

# ===========================================
# EMAIL SERVICE
# ===========================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
# Backend OTP mailer also accepts SMTP_PASS (either works)
EMAIL_FROM=noreply@exchange.com
# OTP email/SMS: direct send from API (fast). Only set true if workers consume queue otp.send.
OTP_USE_RABBITMQ_QUEUE=false

# ===========================================
# SMS SERVICE (Abstract Provider)
# ===========================================
SMS_PROVIDER=twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ===========================================
# KYC PROVIDERS
# ===========================================
KYC_PROVIDER=hyperverge
HYPERVERGE_APP_ID=
HYPERVERGE_APP_KEY=
HYPERVERGE_BASE_URL=https://ind.idv.hyperverge.co/v1
# DigiLocker demo auto-approve: ONLY for dev/demo. Set false in production.
KYC_DIGILOCKER_DEMO_AUTO_APPROVE=false
# KYC document upload directory (default: uploads/kyc)
KYC_UPLOAD_DIR=
# Auth services (optional)
SESSION_CORE_URL=http://localhost:7001/validate
LOCK_SERVICE_URL=http://localhost:7001/lock
# TOTP secret encryption (optional; falls back to ENCRYPTION_KEY)
TOTP_ENCRYPTION_KEY=

# ===========================================
# BLOCKCHAIN RPC ENDPOINTS
# ===========================================
# Ankr API key for indexer RPC/WebSocket - get from https://www.ankr.com/rpc/
# When set, indexer uses Ankr for ETH, BSC, Polygon, Base, Arbitrum.
ANKR_API_KEY=

# EVM Chains (optional overrides for backend and indexer)
ETH_RPC_URL=https://eth.llamarpc.com
ETH_WS_URL=wss://eth.llamarpc.com
BSC_RPC_URL=https://bsc-dataseed1.binance.org
BSC_WS_URL=wss://bsc.publicnode.com
POLYGON_RPC_URL=https://polygon-rpc.com
POLYGON_WS_URL=wss://polygon-bor-rpc.publicnode.com
ARBITRUM_RPC_URL=https://arb1.arbitrum.io/rpc
ARBITRUM_WS_URL=wss://arbitrum-one-rpc.publicnode.com
OPTIMISM_RPC_URL=https://mainnet.optimism.io
BASE_RPC_URL=https://mainnet.base.org
BASE_WS_URL=wss://base-rpc.publicnode.com

# Solana
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
SOLANA_WS_URL=wss://api.mainnet-beta.solana.com

# Tron
TRON_API_URL=https://api.trongrid.io
TRON_API_KEY=

# Bitcoin
BITCOIN_RPC_URL=http://localhost:8332
BITCOIN_RPC_USER=
BITCOIN_RPC_PASSWORD=
BITCOIN_NETWORK=mainnet

# ===========================================
# HOT WALLET (Master Seed - HIGHLY SENSITIVE)
# ===========================================
MASTER_SEED_ENCRYPTED=
MASTER_SEED_KEY_ID=

# ===========================================
# APPLICATION
# ===========================================
NODE_ENV=development
# Backend port (default 4000). Frontend must use the same base for auth/login.
PORT=4000
FRONTEND_URL=http://localhost:3000
API_VERSION=v1

# ===========================================
# FRONTEND (apps/frontend/.env.local)
# ===========================================
# Login and API calls use this base URL. Either name works.
# NEXT_PUBLIC_API_BASE_URL=http://localhost:4000
# NEXT_PUBLIC_API_URL=http://localhost:4000
# Embedded /admin on the user app redirects here (standalone admin-panel, default port 3001).
# NEXT_PUBLIC_ADMIN_PANEL_URL=http://localhost:3001
#
# Tier-1 canonical URLs: middleware 308 /dashboard/spot → /trade/spot (preserves ?symbol=). Default off.
# NEXT_PUBLIC_CANONICAL_ROUTES=true
# Log deprecated path hits (Edge console / log drain): ENABLE_DEPRECATED_ROUTE_LOG=true
#
# Runtime: User UI dev server is apps/frontend on port 3000 (npm run dev or: npm run dev:frontend from repo root).
# Docker Compose "frontend" on :3000 serves a BAKED image — rebuild after route changes:
#   docker compose build --no-cache frontend && docker compose up -d frontend
# Verify routes while dev is running: cd apps/frontend && npm run verify:routes
# Docker Compose sets NEXT_PUBLIC_DOCKER_USER_APP=1 on the user frontend → console warning (baked bundle).
#
# Backend auth routes (must be reachable at BASE_URL/api/v1/auth/...):
#   POST /api/v1/auth/send-otp   - request OTP
#   POST /api/v1/auth/login      - submit OTP and login
#   POST /api/v1/auth/login/verify-step, /login/resend-otp, /login/check-passkeys

# ===========================================
# ADMIN PANEL (apps/admin-panel/.env.local)
# ===========================================
# Backend URL for admin login and API. Admin panel runs on port 3001.
# NEXT_PUBLIC_API_BASE_URL=http://localhost:4000
# NEXT_PUBLIC_API_URL=http://localhost:4000
#
# Before first login: run migrations + seed-admin:
#   cd apps/backend && npm run migrate && npx tsx seed-admin.ts
# Default admin: test@gmail.com / test123

# ===========================================
# RATE LIMITING
# ===========================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_SKIP_SUCCESSFUL_REQUESTS=false
# Tier 1 default: OTP/withdrawal/spot rate limits fail-closed on Redis error (503)
RATE_LIMIT_FAIL_CLOSED=true

# WebSocket connection caps (DoS protection)
WS_MAX_CONNECTIONS_GLOBAL=10000
WS_MAX_CONNECTIONS_PER_USER=5

# ===========================================
# SECURITY
# ===========================================
# Allowed origins for CORS. In development the backend also allows any http://localhost:* and http://127.0.0.1:*.
# Include admin panel origin (port 3001) for admin login and API calls from admin panel.
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3001,http://127.0.0.1:3001,http://localhost:4000,http://127.0.0.1:4000
TRUSTED_PROXIES=1
# Admin API: only these IPs can access /api/v1/admin. Comma-separated; CIDR supported (e.g. 10.0.0.0/8).
# Tier 1 production: REQUIRED. Set office/VPN IPs. Startup fails if empty in production.
ADMIN_IP_WHITELIST=127.0.0.1,::1
SESSION_SECRET=your-session-secret-min-32-chars
CSRF_SECRET=your-csrf-secret-min-32-chars

# Withdrawal approval: amount (in token units) above this requires admin approval. Set tokens.is_high_risk=TRUE to always require approval.
WITHDRAWAL_APPROVAL_THRESHOLD=10000
# New whitelist address: hours before first withdrawal (timelock)
WITHDRAWAL_ADDRESS_COOLING_HOURS=24

# ===========================================
# AML / FIU RULE THRESHOLDS (see docs/AML_RULE_CONFIG.md)
# ===========================================
# Large fiat (INR) transaction alert threshold
AML_LARGE_FIAT_INR_THRESHOLD=1000000
# Large crypto withdrawal alert threshold (in token units / notional)
AML_LARGE_CRYPTO_WITHDRAWAL_THRESHOLD=100000
# Velocity: number of withdrawals in window to trigger alert
AML_VELOCITY_WITHDRAWAL_COUNT=3
AML_VELOCITY_WINDOW_HOURS=24
# High-risk country codes (comma-separated ISO, e.g. KP,IR,SY)
AML_HIGH_RISK_COUNTRIES=KP,IR,SY
# Geo-block: deny access from these countries (comma-separated ISO)
GEO_BLOCKED_COUNTRIES=
# Tier 1: Sanctions screening. In production, must be set or all checks block (fail closed).
# SANCTIONS_PROVIDER=chainalysis
# SANCTIONS_API_URL=https://api.chainalysis.com/api/risk/v2/entities
# SANCTIONS_API_KEY=
#
# FIU-India (VDA reporting entity) — technical readiness (code supports STR/CTR queue + admin APIs).
# Legal: register with FIU-IND, appoint MLRO, file via prescribed channel (e.g. GoAML). Not automated here.
# npm run tier1:fiu-readiness — DB + accounting + AML tables + KYC tables; prints readiness_score /100.
# Production: set SANCTIONS_PROVIDER (+ API). Optional: TIER1_FIU_STRICT=true to fail verify if sanctions unset.
# Admin: GET/PATCH /api/v1/admin/compliance/* (sanctions, withdrawal tier limits, STR/CTR, alert channels).
# TIER1_FIU_STRICT=false

# ===========================================
# MONITORING & LOGGING
# ===========================================
LOG_LEVEL=debug
SENTRY_DSN=
PROMETHEUS_ENABLED=true
PROMETHEUS_PORT=9090
# Tier 1: Slack/PagerDuty webhook for circuit_open, integrity_mismatch. Warned if missing in production.
ALERT_WEBHOOK_URL=

# ===========================================
# FEATURE FLAGS
# ===========================================
# POST /spot/orders: reserve-only path (market-maker reserve). Default false = endpoint returns 410.
# Set true only if you use the reserve-only API; normal trading uses POST /spot/order.
ENABLE_SPOT_ORDERS_RESERVE_ONLY=false
FEATURE_MAKER_REBATES=false
FEATURE_ICEBERG_ORDERS=false
FEATURE_P2P_ENABLED=true
# P2P Tier-1: backend reference price cache (sec), ads list cache (0=off), post-payment release SLA
# P2P_REFERENCE_PRICE_TTL_SEC=3
# P2P_ADS_LIST_CACHE_TTL_SEC=30
# P2P_SLA_RELEASE_MINUTES=15
# P2P_SLA_ACTION=release
# P2P_SLA_WORKER_ENABLED=true
# Require payment screenshot + transaction reference for mark-paid (default true).
# P2P_REQUIRE_PAYMENT_PROOF=true
# P2P_MAX_PAYMENT_PROOF_BYTES=5242880
# P2P_PAYMENT_PROOF_STORAGE=public   # public = legacy static /assets/... ; secure = private data/ + GET /p2p/orders/:id/payment-proof
# P2P risk tiers (INR equivalent for non-INR fiat uses same proxy as existing per-order caps). 0 disables a check.
# P2P_NEW_BUYER_MAX_ACCOUNT_AGE_HOURS=168
# P2P_NEW_BUYER_MAX_ORDER_FIAT_INR_EQUIV=250000
# P2P_UNVERIFIED_SELLER_MAX_ORDER_FIAT_INR_EQUIV=400000
# P2P_VERIFIED_SELLER_MIN_COMPLETED_ORDERS=30
FEATURE_SPOT_TRADING_ENABLED=true
FEATURE_MARGIN_TRADING_ENABLED=false
FEATURE_FUTURES_ENABLED=false
MAINTENANCE_MODE=false

# Tier-1: durable Rust match events → Postgres settlement_events before WS/L2 (retries on failure).
# MATCH_EVENT_PERSIST_RETRIES=3
# SPOT_ENGINE_WS_DEDUP_REDIS=true   # shared dedup across API replicas (set false only for single-node dev)

# Pre-trade risk (spot)
SPOT_ORDER_VELOCITY_PER_MIN=60
SPOT_LARGE_ORDER_NOTIONAL_USDT=100000
SPOT_MAX_OPEN_NOTIONAL_USDT=500000

# RUN_MODE: api (HTTP only), workers (workers only), all (default)
# api mode still starts match poller + settlement worker when USE_RUST_MATCHING_ENGINE=true (so trades settle).
# RUN_MODE=api
# RUN_MODE=workers

# Rust HTTP matching engine is always enabled in code (Node in-process matcher removed). Env kept for compatibility; ignored for enabling/disabling.
USE_RUST_MATCHING_ENGINE=true
MATCHING_ENGINE_URL=http://localhost:7101
# Comma-separated extra engine bases (merged with MATCHING_ENGINE_URL, deduped). Poller calls GET /engine/matches on every instance.
# MATCHING_ENGINE_URLS=http://127.0.0.1:7101,http://127.0.0.1:7102
# Parallel instance ids (optional; default single=default, multi=engine_0,…). Must match ENGINE_INSTANCE_ID on each engine process.
# MATCHING_ENGINE_INSTANCE_IDS=eng-a,eng-b
# Phase 1 (optional): per-market base URL for POST /engine/place. Route URLs must be listed in MATCHING_ENGINE_URL / MATCHING_ENGINE_URLS.
# MATCHING_ENGINE_SHARD_ROUTING_ENABLED=false
# Reject places for markets not listed in MATCHING_ENGINE_ROUTES (no fallback to primary).
# MATCHING_ENGINE_STRICT_MARKET_ROUTING=false
# Reject POST /engine/place when /health reports instance down (poller still polls all instances).
# MATCHING_ENGINE_SKIP_UNHEALTHY_FOR_PLACE=true
# MATCHING_ENGINE_ROUTES=BTC_USDT=http://127.0.0.1:7101,ETH_USDT=http://127.0.0.1:7102
# Rust matching-engine: stable id for multi-instance (must align with MATCHING_ENGINE_INSTANCE_IDS)
# ENGINE_INSTANCE_ID=default
# ENGINE_HTTP_PORT=7101
# Tier-1 engine rebuild: backend URL for GET /internal/engine/state (set in engine env)
# ENGINE_BACKEND_URL=http://localhost:4000
# Shared secret for engine→backend internal API (optional; both must match)
# ENGINE_INTERNAL_SECRET=

# NATS JetStream (optional): engine/API → spot.match.* → orderbook writer → spot.orderbook.* / ticker / trades
# Local: npm run infra:nats   or   docker compose up -d nats
# NATS_URL=nats://127.0.0.1:4222
#
# Match events → JetStream MATCH_EVENTS (match.events.*) → settlement_group_p* consumers → Postgres. DLQ: MATCH_SETTLEMENT_DLQ.
# Partition count must match between engine (MATCH_EVENTS_PARTITIONS) and backend (MATCH_EVENTS_PARTITION_COUNT).
# USE_EVENT_STREAM=false
# MATCH_EVENTS_PARTITION_COUNT=1
# SETTLEMENT_STREAM_PULL_BATCH=32
# SETTLEMENT_STREAM_PULL_INTERVAL_MS=250
# SETTLEMENT_STREAM_MAX_ACK_PENDING=64
# SETTLEMENT_STREAM_ACK_WAIT_MS=60000
# SETTLEMENT_STREAM_MAX_DELIVER=12
# EVENT_STREAM_MATCH_POLLER_FALLBACK=true
# Async publish (default): orderbook lock not held during NATS; optional WAL. Sync: ENGINE_STREAM_SYNC_PUBLISH=true (503 if publish fails).
# ENGINE_STREAM_PUBLISH_MAX_RETRIES=8
# ENGINE_STREAM_PUBLISH_BACKOFF_MS=50
# ENGINE_PUBLISH_QUEUE_CAPACITY=262144
# ENGINE_PUBLISH_BATCH_SIZE=64
# ENGINE_PUBLISH_PARALLEL=32
# Tier-1: with USE_EVENT_STREAM, require durable WAL (refuses startup if unset)
# ENGINE_TIER1_WAL_REQUIRED=true
# TIER1_LAUNCH=true
#
# Tier-1 periodic reconciliation (API/worker process): ledger coverage, balance audits, settlement replay — logs/alerts only, no auto-fix.
# DISABLE_TIER1_RECONCILIATION=false
# TIER1_RECONCILIATION_INTERVAL_MS=600000
#
# When true, destructive admin settlement actions require JSON { "confirm": true } (circuit reset, balance reconcile).
# ADMIN_REQUIRE_DESTRUCTIVE_CONFIRM=false
# ENGINE_MATCH_WAL_PATH=/var/lib/matching-engine/wal   # file or directory (→ match_events.jsonl)
# HOT_MARKET_PARTITION_MAP=BTC_USDT:0,ETH_USDT:1
# Active–passive: passive rejects POST /engine/place and /engine/cancel; use GET /engine/snapshot to sync
# ENGINE_REPLICATION_ROLE=passive
# Local persistence: full order book + book_applied_match_event_ids (preferred over backend-only recovery)
# ENGINE_PERSISTENCE_SNAPSHOT_PATH=/var/lib/matching-engine/engine-snapshot.json
# ENGINE_SNAPSHOT_INTERVAL_SECS=60
# ENGINE_SNAPSHOT_STRICT_ENGINE_ID=true
# Default true: rewrite WAL to unacked evt lines only before open (set false to skip)
# ENGINE_WAL_COMPACT_ON_START=true
# MATCH_EVENTS_PARTITIONS=8
# ENGINE_INSTANCE_ID=default
# NATS_SPOT_PIPELINE_ENABLED=true
# NATS_ORDERBOOK_WRITER_ENABLED=true
# NATS_WS_ORDERBOOK_FORWARDER_ENABLED=true
# When writer and WS run in the same process, set true to broadcast locally and skip the forwarder pull consumers.
# NATS_WRITER_LOCAL_WS_BROADCAST=true
# ORDERBOOK_SHARD_ID=0
# ORDERBOOK_SHARD_TOTAL=1
# ORDERBOOK_SNAPSHOT_INTERVAL_MS=60000
# ORDERBOOK_SNAPSHOT_PATH=
# Optional URI for ops (S3 prefix, etc.); embedded in snapshot JSON for audit only.
# ORDERBOOK_SNAPSHOT_STORAGE_URI=
# Strict per-symbol writer_seq (gap → orderbook_resync). Enable with Redis publisher seq.
# ORDERBOOK_WRITER_STRICT_SEQ=false
# ORDERBOOK_PUBLISHER_ASSIGN_SEQ=true
# ORDERBOOK_WRITER_DEDUP_REDIS=true
# ORDERBOOK_WRITER_DEDUP_TTL_SEC=86400
# ORDERBOOK_WRITER_LAG_PENDING_THRESHOLD=50000
# ORDERBOOK_WRITER_PULL_MS_FAST=150
# ORDERBOOK_WRITER_PULL_MS_SLOW=500
# Redis leader election: only holder consumes JetStream for this shard (failover < lease TTL).
# ORDERBOOK_WRITER_LEADER_TTL_MS=5000
# ORDERBOOK_WRITER_LEADER_ELECTION=true
# Trip Redis spot:orderbook_writer_lag_circuit → API rejects new spot orders (cancels still allowed).
# ORDERBOOK_WRITER_LAG_CIRCUIT_MS=5000
# ORDERBOOK_WRITER_LAG_CIRCUIT_PENDING=50000
# Redis token-bucket burst limits (per 1s window). 0 = disabled.
# SPOT_ORDER_BURST_PER_SEC=50
# SPOT_CANCEL_BURST_PER_SEC=80
# SPOT_WS_SUBSCRIBE_BURST_PER_SEC=30
# SPOT_WRITER_LOG_SAMPLE_RATE=0.001
# LOG_JSON=false
# WS NATS forwarder: adaptive shedding (tier1=drop ticker, tier2=drop trades+ticker). Orderbook never dropped.
# WS_FORWARDER_SHED_ENABLED=true
# WS_FORWARDER_SHED_T1_PENDING=3000
# WS_FORWARDER_SHED_T2_PENDING=15000
# WS_FORWARDER_SHED_T1_LAG_MS=400
# WS_FORWARDER_SHED_T2_LAG_MS=2000
# WS_FORWARDER_SHED_T1_BACKLOG_BYTES=262144
# WS_FORWARDER_SHED_T2_BACKLOG_BYTES=1572864
# WS_FORWARDER_SHED_TELEMETRY_MS=500
# Writer + WS same process: coalesce ticker, batch trades under load, per-conn backpressure (orderbook exempt).
# WS_WRITER_LOCAL_OPTIMIZE_ENABLED=true
# WS_WRITER_LOCAL_SHED_ENABLED=true
# WS_WRITER_LOCAL_TICKER_COALESCE_MS=8
# WS_WRITER_LOCAL_TRADES_BATCH_MS=20
# WS_WRITER_LOCAL_TRADES_BATCH_MAX=32
# WS_WRITER_LOCAL_TRADES_BATCH_MIN_BACKLOG_BYTES=131072
# WS_WRITER_LOCAL_PER_CONN_SOFT_BUFFER_BYTES=131072
# WS_WRITER_LOCAL_PER_CONN_HARD_BUFFER_BYTES=524288
# Optional per-stream backpressure (0 = use generic soft/hard above).
# WS_WRITER_LOCAL_PER_CONN_SOFT_TICKER_BYTES=
# WS_WRITER_LOCAL_PER_CONN_HARD_TICKER_BYTES=
# WS_WRITER_LOCAL_PER_CONN_SOFT_TRADES_BYTES=
# WS_WRITER_LOCAL_PER_CONN_HARD_TRADES_BYTES=
# Stretch coalesce/batch windows under lag (tier2 lag reference).
# WS_WRITER_LOCAL_DYNAMIC_COALESCE=true
# WS_WRITER_LOCAL_TICKER_COALESCE_MAX_MS=48
# WS_WRITER_LOCAL_TRADES_BATCH_MS_MAX=80
# Optional: merge orderbook_delta bursts (never coalesces orderbook_resync).
# WS_WRITER_LOCAL_ORDERBOOK_BURST_COALESCE=false
# WS_WRITER_LOCAL_ORDERBOOK_BURST_MS=12
# WS_WRITER_LOCAL_ORDERBOOK_BURST_MS_MAX=40
# WS_WRITER_LOCAL_ORDERBOOK_BURST_MIN_LAG_MS=120
# WS message type adaptive_mode to all connections (UI throttling hints).
# WS_WRITER_LOCAL_ADAPTIVE_MODE=true
# WS_WRITER_LOCAL_ADAPTIVE_MODE_MIN_MS=2000
# PID coalesce multiplier (replaces pure linear lag ramp when WS_WRITER_LOCAL_PID_ENABLED=true).
# WS_WRITER_LOCAL_PID_ENABLED=true
# WS_PID_SETPOINT_LAG_MS=90
# WS_PID_KP=0.004
# WS_PID_KI=0.0006
# WS_PID_KD=0.0012
# WS_PID_INTEGRAL_MAX=800
# WS_PID_UMIN=-0.22
# WS_PID_UMAX=1.1
# WS_PID_COALESCE_MIN_MULT=0.94
# WS_PID_COALESCE_MAX_MULT=2.35
# Soft backpressure → priority queue (orderbook>trades>ticker) instead of drop.
# WS_WRITER_LOCAL_PUBLIC_QUEUE=false
# WS_PUBLIC_QUEUE_MAX=96
# WS_PUBLIC_QUEUE_DRAIN_MS=5
# Client net_metrics → inflate PID process variable (RTT ms × factor + loss% × ms/pt).
# WS_NET_ADAPT_ENABLED=true
# WS_NET_RTT_INFLATION_PER_MS=0.42
# WS_NET_LOSS_MS_PER_PERCENT=2.8
# WS_NET_INFLATION_CAP_MS=800

# Phase D: Price oracle (Binance ticker → market_prices). For convert, balances, liquidity bot mid.
PRICE_ORACLE_ENABLED=false
PRICE_ORACLE_INTERVAL_SEC=120

# Phase D: Internal liquidity bot. Needs API key for bot user; uses oracle mid + spread.
LIQUIDITY_BOT_ENABLED=false
# LIQUIDITY_BOT_API_KEY=
# Base URL for bot HTTP calls (default http://127.0.0.1:PORT when unset). Use internal service URL in k8s/docker.
# LIQUIDITY_BOT_INTERNAL_API_URL=http://127.0.0.1:4000
LIQUIDITY_BOT_SPREAD_BPS=10
LIQUIDITY_BOT_ORDER_SIZE=0.001
LIQUIDITY_BOT_SYMBOLS=BTC_USDT,ETH_USDT,BNB_USDT,SOL_USDT,XRP_USDT,ADA_USDT,AVAX_USDT,DOT_USDT,ATOM_USDT,NEAR_USDT,SUI_USDT,APT_USDT,SEI_USDT,TRX_USDT,LTC_USDT,MATIC_USDT,ARB_USDT,OP_USDT,UNI_USDT,AAVE_USDT,LINK_USDT,MKR_USDT,INJ_USDT,DOGE_USDT,SHIB_USDT,PEPE_USDT,WIF_USDT,FET_USDT,RENDER_USDT,WLD_USDT,FIL_USDT,GRT_USDT,ICP_USDT,HBAR_USDT,VET_USDT
# Oracle staleness: widen spread or skip cycle when market_prices.last_updated is older than this (seconds).
# LIQUIDITY_BOT_ORACLE_STALE_SEC=300
# LIQUIDITY_BOT_STALE_SPREAD_MULTIPLIER=2
# LIQUIDITY_BOT_SKIP_IF_ORACLE_STALE=false
# Reprice only when mid moves ≥ bps or relative qty change ≥ threshold (avoid cancel-all churn).
# LIQUIDITY_BOT_REPRICE_BPS_THRESHOLD=5
# LIQUIDITY_BOT_REPRICE_QTY_REL_THRESHOLD=0.02
# Extra UUIDs exempt from spot Redis order/cancel rate limits (bot user from API key is auto-exempt after warm).
# LIQUIDITY_BOT_RATE_LIMIT_EXEMPT_USER_IDS=

# MM intelligence layer: health-driven spread widening + optional auto-pause (liquidity bot).
# MM_HEALTH_ENABLED=true
# MM_HEALTH_ORACLE_CRITICAL_SEC=900
# MM_HEALTH_SETTLEMENT_LAG_CRITICAL_SEC=120
# MM_HEALTH_BOT_ERROR_WINDOW=20
# MM_HEALTH_BOT_ERROR_RATE_CRITICAL=0.55
# MM_HEALTH_BOT_ERROR_RATE_WARN=0.28
# MM_HEALTH_QUOTE_AGE_CRITICAL_SEC=900
# MM_HEALTH_MIN_CYCLES_BEFORE_QUOTE_CHECK=4
# MM_HEALTH_EXTERNAL_DIVERGENCE_WARN_BPS=40
# MM_HEALTH_EXTERNAL_DIVERGENCE_CRITICAL_BPS=120
# MM_HEALTH_SPREAD_MULT_DEGRADED=1.5
# MM_HEALTH_SPREAD_MULT_BAD=2.5
# MM_HEALTH_AUTO_PAUSE_ON_CRITICAL=true
# Compare oracle mid to Binance (or EXTERNAL_PRICE_FEED_BASE_URL host implementing same /api/v3/ticker/price API).
# EXTERNAL_PRICE_FEED_ENABLED=false
# EXTERNAL_PRICE_FEED_BASE_URL=https://api.binance.com
# Comma-separated Binance-compatible roots; median/mean aggregated for health checks.
# EXTERNAL_PRICE_FEED_SOURCES=https://api.binance.com,https://api.binance.us
# EXTERNAL_PRICE_FEED_AGGREGATION=median
# EXTERNAL_PRICE_OUTLIER_MAX_BPS=0
# EXTERNAL_PRICE_LATENCY_WEIGHT=false
