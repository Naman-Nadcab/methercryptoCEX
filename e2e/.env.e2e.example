# Copy to .env.e2e or export before `npm run test:e2e`
E2E_BASE_URL=http://localhost:4000
E2E_ENGINE_URL=http://localhost:7101
#
# Generate working JWT + API keys (DB + Redis must match the API; backend should not be required):
#   npm run qa:e2e-credentials
# Paste the printed E2E_* lines here. Users: qa_trader_a@local.exchange / qa_trader_b@local.exchange (password TestPass123).
#
# Bearer JWT for user A (maker in Phase 3 cross-trade when paired with counterparty API key):
# E2E_JWT=eyJ...
# Optional: second-user JWT (Phase 14 private WS):
# E2E_COUNTERPARTY_JWT=eyJ...
# Or API key for user A:
# E2E_API_KEY=aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa
# Second user API key for a real cross on BTC_USDT (required for trade + dual-side history checks):
# E2E_COUNTERPARTY_API_KEY=bbbbbbbbbbbbbbbbbbbbbbbbbbbbbbbb
# Second user JWT (required for Phase 14 private WS on taker side):
# E2E_COUNTERPARTY_JWT=eyJ...
# E2E_MATCH_PRICE=876543.21
# Private WS event budget (ms) after taker places:
# E2E_PRIVATE_WS_MAX_MS=8000
# Private WS latency SLO (separate from event budget; Phase 14 fails if exceeded):
# E2E_WS_MAX_LATENCY_MS=500
E2E_TIMEOUT_MS=15000
E2E_WS_SOAK_MS=12000
# After soak, run REST vs WS parity inside Phase 9:
# E2E_WS_PARITY=true
# Stricter observability (Phase 13 extension):
# E2E_EXPECT_INDEXER_METRIC=true
# E2E_EXPECT_WS_METRIC=true
# E2E_ALLOW_DEGRADED_HEALTH=true
#
# Tier-1 orchestrator: npm run test:tier1
# TIER1_WS_SOAK_MS=300000
# TIER1_K6=true
# TIER1_CHAOS=true
