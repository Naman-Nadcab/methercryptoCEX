{
  "name": "crypto-exchange",
  "version": "1.0.0",
  "private": true,
  "description": "Enterprise-grade Spot Trading + P2P Cryptocurrency Exchange",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "ulimit -n 10240 2>/dev/null; turbo run dev",
    "dev:frontend": "npm run dev --workspace=@exchange/frontend",
    "dev:admin-panel": "npm run dev --workspace=@exchange/admin-panel",
    "dev:fb": "ulimit -n 10240 2>/dev/null; turbo run dev --filter=@exchange/frontend --filter=@exchange/backend",
    "dev:admin": "ulimit -n 10240 2>/dev/null; turbo run dev --filter=@exchange/backend --filter=@exchange/admin-panel",
    "dev:stack": "bash scripts/dev-stack.sh",
    "docker:frontend:rebuild": "docker compose build --no-cache frontend && docker compose up -d frontend",
    "dev:all": "(docker compose up -d redis rabbitmq 2>/dev/null || docker-compose up -d redis rabbitmq 2>/dev/null || true) && npm run dev",
    "build": "turbo run build",
    "start": "turbo run start",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "e2e": "playwright test",
    "e2e:smoke": "playwright test e2e/smoke.spec.ts",
    "e2e:install": "playwright install chromium",
    "e2e:ui": "playwright test --ui",
    "test:e2e": "tsx e2e/run-e2e.ts",
    "test:tier1": "tsx e2e/run-tier1-proof.ts",
    "test:security": "tsx security/run-security-tests.ts",
    "smoke:api": "node scripts/smoke-api.mjs",
    "test:e2e:provisioned": "bash scripts/run-e2e-provisioned.sh",
    "test:security:provisioned": "bash scripts/run-security-provisioned.sh",
    "load:health:quick": "bash scripts/run-k6-health-quick.sh",
    "verify:load-gate": "node scripts/load-gate.mjs",
    "drill:incident": "bash scripts/incident-drill.sh",
    "verify:monitoring-slo": "node scripts/monitoring-slo-check.mjs",
    "verify:compliance-signoff": "node scripts/compliance-signoff.mjs",
    "verify:compliance-signoff:strict": "COMPLIANCE_STRICT=1 node scripts/compliance-signoff.mjs",
    "release:go-no-go": "node scripts/release-go-no-go.mjs",
    "release:go-no-go:strict": "RELEASE_STRICT_PROFILE=1 node scripts/release-go-no-go.mjs",
    "qa:e2e-credentials:file": "cd apps/backend && npx tsx scripts/e2e-provision-credentials.ts --emit-json ../../e2e/.e2e-credentials.json",
    "load": "k6 run load/k6-spot-order.js",
    "load:health": "k6 run load/k6-health-markets.js",
    "load:stress": "k6 run load/k6-high-throughput.js",
    "load:docker:health": "docker run --rm -i --add-host=host.docker.internal:host-gateway -e BASE_URL=http://host.docker.internal:4000 grafana/k6:latest run - < load/k6-health-markets.js",
    "qa:provision-traders": "cd apps/backend && npx tsx ../../scripts/dev-provision-qa-traders.ts",
    "qa:e2e-credentials": "cd apps/backend && npx tsx scripts/e2e-provision-credentials.ts",
    "prelive:verify": "bash -c 'export TIER1_AUTO_RECONCILE=1; npm run prelaunch:db --workspace=@exchange/backend && npm run tier1:release-check:full --workspace=@exchange/backend'",
    "prelive:verify:noapi": "bash -c 'export TIER1_AUTO_RECONCILE=1 TIER1_SKIP_HTTP_CHECKS=1 TIER1_PHASE3_SKIP_SECURITY=true; npm run prelaunch:db --workspace=@exchange/backend && npm run tier1:release-check:full --workspace=@exchange/backend'",
    "prelive:verify:local": "bash scripts/prelive-verify-full-local.sh",
    "prelaunch:db": "npm run prelaunch:db --workspace=@exchange/backend",
    "tier1:phase1-verify": "npm run tier1:phase1-verify --workspace=@exchange/backend",
    "tier1:phase2-verify": "npm run tier1:phase2-verify --workspace=@exchange/backend",
    "tier1:phase3-verify": "npm run tier1:phase3-verify --workspace=@exchange/backend",
    "tier1:fiu-readiness": "npm run tier1:fiu-readiness --workspace=@exchange/backend",
    "tier1:drain-settlement": "npm run tier1:drain-settlement --workspace=@exchange/backend",
    "tier1:release-check:db": "npm run tier1:release-check:db --workspace=@exchange/backend",
    "tier1:release-check:full": "npm run tier1:release-check:full --workspace=@exchange/backend",
    "tier1:release-check:strict": "npm run tier1:release-check:strict --workspace=@exchange/backend",
    "settlement:reset": "npm run settlement:reset --workspace=@exchange/backend",
    "db:migrate": "npm run migrate --workspace=@exchange/backend",
    "db:seed": "echo 'No monorepo seed script: migrations seed BTC_USDT when currencies exist; create users via /signup or admin.' && exit 0",
    "docker:up": "(docker compose up -d 2>/dev/null || docker-compose up -d)",
    "infra:up": "docker compose up -d redis postgres rabbitmq nats",
    "p0:infra": "docker compose up -d redis postgres rabbitmq nats indexer",
    "p0:verify": "bash scripts/p0-prelive-verify.sh",
    "system:ready": "bash scripts/system-ready.sh",
    "system:verify": "bash scripts/verify-dev-stack.sh",
    "infra:redis": "docker compose up -d redis",
    "infra:nats": "docker compose up -d nats",
    "verify:infra": "bash scripts/tier1-stack-verify.sh",
    "verify:tier1-alerts": "npm run test:tier1-alerts --workspace=@exchange/backend",
    "docker:down": "docker-compose down",
    "clean": "turbo run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "turbo": "^2.0.0",
    "tsx": "^4.6.2",
    "typescript": "^5.3.3",
    "ws": "^8.14.2"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "packageManager": "npm@10.2.0"
}
